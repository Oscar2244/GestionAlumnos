APP_NAME="Gestión de Alumnos"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Asuncion
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Base de datos: SQLite ---
# No se necesita usuario, contraseña ni servidor de base de datos.
# Laravel va a leer/escribir directamente en database/database.sqlite
DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync
